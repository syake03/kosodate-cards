---
import '../styles/tokens.css';

interface Props {
  title?: string;
  description?: string;
}
const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
const siteName = '子育ての地図';
const pageTitle = title ? `${title}｜${siteName}` : siteName;
const desc =
  description ??
  '医学の「標準治療」の子育て版。エビデンスに基づく推奨を、エビデンス強度と影響度の2軸で構造化して無料公開します。';
// OGP・canonical 用の絶対URL（astro.config.mjs の site + 現在パス）
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

const nav = [
  { href: `${base}`, label: 'ホーム' },
  { href: `${base}age/`, label: '年齢から' },
  { href: `${base}domain/`, label: '領域から' },
  { href: `${base}search/`, label: '検索' },
  { href: `${base}methodology/`, label: '評価基準' },
  { href: `${base}about/`, label: 'このサイト' },
];
---

<!doctype html>
<html lang="ja" data-audience="parent">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Zen+Old+Mincho:wght@500;700&family=Noto+Sans+JP:wght@400;500;700&family=IBM+Plex+Mono:wght@500;600&display=swap"
      rel="stylesheet"
    />
    <!-- 本人／専門家トグルの初期状態（既定は本人向け）。ちらつき防止で head で適用。 -->
    <script is:inline>
      try {
        var a = localStorage.getItem('audience') === 'expert' ? 'expert' : 'parent';
        document.documentElement.dataset.audience = a;
      } catch (e) {
        document.documentElement.dataset.audience = 'parent';
      }
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">本文へスキップ</a>
    <header class="site-header">
      <div class="wrap header-inner">
        <a class="brand" href={base}>
          <span class="brand-name">子育ての地図</span>
        </a>
        <nav class="site-nav" aria-label="サイト内ナビゲーション">
          {nav.map((n) => <a href={n.href}>{n.label}</a>)}
        </nav>
      </div>
    </header>

    <main id="main" class="wrap">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <p class="disclaimer-lead">
          本サイトは一般的な情報提供であり、個別の医療・心理・法的アドバイスではありません。診断・治療・緊急対応は必ず専門家・医療機関へ。
          <strong>AI（Claude）による調査補助で作成</strong>しており、誤り・古い情報が含まれうるため、各カードの出典をご確認ください。
        </p>
        <nav class="footer-nav" aria-label="フッター">
          <a href={`${base}about/`}>このサイトについて</a>
          <a href={`${base}methodology/`}>評価基準（方法論）</a>
          <a href={`${base}disclaimer/`}>免責事項</a>
        </nav>
        <p class="copy">出典はできる限り一次資料（学会・公的機関・システマティックレビュー）に基づきます。</p>
      </div>
    </footer>

    <style is:global>
      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        *,
        *::before,
        *::after {
          animation-duration: 0.001ms !important;
          transition-duration: 0.001ms !important;
        }
      }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: var(--font-body);
        font-size: 16px;
        line-height: 1.8;
        -webkit-font-smoothing: antialiased;
      }
      .wrap {
        max-width: var(--maxw);
        margin-inline: auto;
        padding-inline: 20px;
      }
      a {
        color: var(--accent);
        text-decoration-thickness: 1px;
        text-underline-offset: 2px;
      }
      h1,
      h2,
      h3 {
        font-family: var(--font-display);
        line-height: 1.35;
        color: var(--ink);
      }
      :focus-visible {
        outline: 3px solid var(--accent);
        outline-offset: 2px;
        border-radius: 3px;
      }
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--accent);
        color: #fff;
        padding: 8px 14px;
        z-index: 100;
      }
      .skip-link:focus {
        left: 8px;
        top: 8px;
      }

      /* header */
      .site-header {
        background: var(--surface);
        border-bottom: 1px solid var(--line);
        position: sticky;
        top: 0;
        z-index: 50;
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding-block: 12px;
        flex-wrap: wrap;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: var(--ink);
      }
      .brand-name {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.05rem;
      }
      .site-nav {
        display: flex;
        gap: 4px 2px;
        flex-wrap: wrap;
      }
      .site-nav a {
        color: var(--ink-soft);
        text-decoration: none;
        font-size: 0.9rem;
        padding: 6px 10px;
        border-radius: 6px;
      }
      .site-nav a:hover {
        background: var(--accent-weak);
        color: var(--accent);
      }

      main {
        padding-block: 32px 56px;
        min-height: 60vh;
      }

      /* footer */
      .site-footer {
        border-top: 1px solid var(--line);
        background: var(--surface);
        padding-block: 28px 40px;
      }
      .disclaimer-lead {
        font-size: 0.85rem;
        color: var(--ink-soft);
        max-width: 70ch;
      }
      .footer-nav {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
        margin-block: 12px;
        font-size: 0.9rem;
      }
      .copy {
        font-size: 0.78rem;
        color: var(--ink-soft);
        margin: 0;
      }
    </style>
  </body>
</html>
