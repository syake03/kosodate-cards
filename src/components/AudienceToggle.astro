---
// SPEC.md §8 の表示切替（まず要点／くわしく）。既定は「まず要点」。
// 読者の属性ではなく読む深さ・順番の切替なので、ラベルも深さで名乗る。
// data-audience の値（parent/expert）は互換のため変えない。
// 状態は <html data-audience> と localStorage で保持する。
---

<div class="audience-toggle" role="group" aria-label="表示の切り替え">
  <span class="at-label">表示：</span>
  <div class="at-buttons">
    <button type="button" data-audience-set="parent" class="at-btn">まず要点</button>
    <button type="button" data-audience-set="expert" class="at-btn">くわしく</button>
  </div>
  <p class="at-hint" data-audience-hint></p>
</div>

<script is:inline>
  (function () {
    var root = document.documentElement;
    var btns = document.querySelectorAll('[data-audience-set]');
    var hintEl = document.querySelector('[data-audience-hint]');
    var HINTS = {
      parent: '「具体的にどうする」と「よくある誤解」を先頭に出します。',
      expert: '「なぜ」から始め、エビデンスの限界・出典まで全面展開します。',
    };
    function apply(mode) {
      root.dataset.audience = mode;
      try {
        localStorage.setItem('audience', mode);
      } catch (e) {}
      btns.forEach(function (b) {
        var on = b.getAttribute('data-audience-set') === mode;
        b.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
      if (hintEl) hintEl.textContent = HINTS[mode] || '';
    }
    btns.forEach(function (b) {
      b.addEventListener('click', function () {
        apply(b.getAttribute('data-audience-set'));
      });
    });
    apply(root.dataset.audience === 'expert' ? 'expert' : 'parent');
  })();
</script>

<style>
  .audience-toggle {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 6px 12px;
  }
  .at-label {
    font-size: 0.82rem;
    color: var(--ink-soft);
  }
  .at-buttons {
    display: inline-flex;
    background: var(--bg);
    border-radius: 999px;
    padding: 3px;
    gap: 2px;
  }
  .at-btn {
    border: none;
    background: transparent;
    color: var(--ink-soft);
    font-family: var(--font-body);
    font-size: 0.85rem;
    padding: 5px 14px;
    border-radius: 999px;
    cursor: pointer;
  }
  .at-btn[aria-pressed='true'] {
    background: var(--accent);
    color: #fff;
  }
  .at-hint {
    flex-basis: 100%;
    margin: 2px 0 0;
    font-size: 0.76rem;
    color: var(--ink-soft);
  }
</style>
