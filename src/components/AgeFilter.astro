---
import { AGES } from '../lib/taxonomy';

/*
  年齢しぼりこみ。JSなしのCSSのみで動く（ラジオ＋:has()）。
  .filterable でこのフィールドセットと .card-grid を囲んだ上で使う。
  カードが少ない領域では押しても意味がないため、出すかどうかは呼び出し側が決める。
*/
interface Props {
  /** 年齢ID→その年齢に該当するカード枚数。0枚の年齢は選択肢に出さない。 */
  counts: Record<string, number>;
  total: number;
}
const { counts, total } = Astro.props;
const options = AGES.filter((a) => (counts[a.id] ?? 0) > 0);

// Astroのスコープ付きスタイルは他コンポーネント由来の .card-grid / .card に当たらないため、
// 絞り込みの規則だけは素のCSSとして出す。
const rules = options
  .map(
    (a) =>
      `.filterable:has(#agef-${a.id}:checked) .card-grid > *:not([data-ages~="${a.id}"]){display:none}`
  )
  .join('\n');
---

<fieldset class="age-filter">
  <legend>年齢でしぼりこむ</legend>
  <div class="opts">
    <input class="vh" type="radio" name="agef" id="agef-all" checked />
    <label for="agef-all">すべて<span class="n">{total}</span></label>
    {
      options.map((a) => (
        <>
          <input class="vh" type="radio" name="agef" id={`agef-${a.id}`} />
          <label for={`agef-${a.id}`}>
            {a.label}
            <span class="n">{counts[a.id]}</span>
          </label>
        </>
      ))
    }
  </div>
</fieldset>

<style is:inline set:html={rules}></style>

<style>
  .age-filter {
    border: none;
    margin: 0 0 18px;
    padding: 0;
    min-inline-size: 0; /* fieldset 既定の min-width:min-content で grid がはみ出すのを防ぐ */
  }
  .age-filter legend {
    font-size: 0.78rem;
    color: var(--ink-soft);
    padding: 0;
    margin-bottom: 8px;
    letter-spacing: 0.04em;
  }
  .opts {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .vh {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }
  .opts label {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    cursor: pointer;
    font-size: 0.85rem;
    color: var(--ink-soft);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 7px 13px;
    user-select: none;
  }
  .opts label:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .n {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    background: rgba(0, 0, 0, 0.06);
    border-radius: 999px;
    padding: 0 6px;
  }
  .vh:checked + label {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  .vh:checked + label .n {
    background: rgba(255, 255, 255, 0.25);
  }
  .vh:focus-visible + label {
    outline: 3px solid var(--accent);
    outline-offset: 2px;
  }
</style>
