---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
---

<Base title="ページが見つかりません">
  <div class="nf">
    <p class="nf-code">404</p>
    <h1>ページが見つかりません</h1>
    <p>お探しのページは移動または削除された可能性があります。</p>
    <p><a href={base}>ホームに戻る</a></p>
  </div>
  <style>
    .nf {
      text-align: center;
      padding: 60px 0;
    }
    .nf-code {
      font-family: var(--font-mono);
      font-size: 3rem;
      color: var(--accent);
      margin: 0;
    }
  </style>
</Base>
